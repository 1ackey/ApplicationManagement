{
  "name": "internship-application-management-system",
  "version": "1.0.0",
  "description": "校企合作实习投递系统 Internship Application Management System - Express + SQLite Web 实现",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "reset-db": "node src/resetDb.js",
    "css:build": "tailwindcss -i src/public/styles/tailwind.css -o public/styles/output.css",
    "css:watch": "tailwindcss -i src/public/styles/tailwind.css -o public/styles/output.css --watch"
  },
  "keywords": [
    "internship",
    "application",
    "management",
    "express",
    "sqlite"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "connect-sqlite3": "^0.9.0",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.4.1"
  }
