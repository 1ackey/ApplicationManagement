<div class="max-w-4xl mx-auto px-2 sm:px-4 lg:px-0 py-4 sm:py-8">
  <div class="mb-6 sm:mb-10">
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">简历管理</h1>
    <p class="text-sm sm:text-base text-gray-500 mt-1 sm:mt-2">上传PDF格式的简历文件，新简历会覆盖</p>
  </div>

  <div class="bg-white shadow-[0_8px_30px_rgb(0,0,0,0.04)] rounded-lg sm:rounded-2xl border border-gray-100 overflow-hidden">
    <div class="p-4 sm:p-8 md:p-12">
      
      <% if (profile.resume_url) { %>
      <div class="mb-6 sm:mb-10 p-4 sm:p-6 bg-emerald-50/50 border border-emerald-100 rounded-lg sm:rounded-2xl flex flex-col sm:flex-row items-start sm:items-center justify-between animate-in fade-in duration-500 gap-4">
        <div class="flex items-start sm:items-center gap-3">
          <div class="flex-shrink-0 w-10 sm:w-12 h-10 sm:h-12 bg-white rounded-lg sm:rounded-xl shadow-sm flex items-center justify-center text-emerald-600">
            <svg class="w-5 sm:w-6 h-5 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <div>
            <a href="<%= profile.resume_url %>" target="_blank" class="text-base sm:text-lg font-bold text-gray-900 hover:text-indigo-600 transition-colors flex items-center gap-1 break-all">
              查看简历
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
            </a>
            <p class="text-xs sm:text-sm text-emerald-700 mt-1">简历已上传</p>
          </div>
        </div>
        <span class="px-3 py-1.5 bg-white border border-emerald-200 text-emerald-700 text-xs font-bold rounded-full shadow-sm">
          VALIDATED
        </span>
      </div>
      <% } else { %>
      <div class="mb-6 sm:mb-10 p-4 sm:p-6 bg-amber-50 border border-amber-100 rounded-lg sm:rounded-2xl flex items-start gap-3 animate-pulse">
        <div class="flex-shrink-0 w-10 sm:w-12 h-10 sm:h-12 bg-white rounded-lg sm:rounded-xl flex items-center justify-center text-amber-500">
          <svg class="w-5 sm:w-6 h-5 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
        </div>
        <div>
          <p class="text-sm sm:text-base font-bold text-amber-800">简历缺失</p>
          <p class="text-xs sm:text-sm text-amber-700">企业目前无法查看您的详细信息</p>
        </div>
      </div>
      <% } %>

      <div class="space-y-4 sm:space-y-6">
        <h4 class="text-lg sm:text-xl font-bold text-gray-900">更新简历档案</h4>
        
        <form method="post" action="/student/profile/resume" enctype="multipart/form-data" class="group" id="resume-form">
          <label id="drop-zone" class="relative flex flex-col items-center justify-center w-full min-h-[240px] sm:min-h-[280px] border-2 border-dashed border-gray-200 rounded-lg sm:rounded-2xl cursor-pointer hover:border-indigo-400 hover:bg-indigo-50/30 transition-all duration-300 group p-4">
            
            <div class="text-center p-4 sm:p-6" id="upload-placeholder">
              <div class="w-12 sm:w-16 h-12 sm:h-16 bg-indigo-50 text-indigo-500 rounded-lg sm:rounded-2xl flex items-center justify-center mx-auto mb-3 sm:mb-4 group-hover:scale-110 transition-transform duration-300">
                <svg class="w-6 sm:w-8 h-6 sm:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
              </div>
              <p class="text-gray-900 font-bold text-base sm:text-lg">点击或拖拽文件</p>
              <p class="text-gray-400 text-xs sm:text-sm mt-1 sm:mt-2 font-medium max-w-xs mx-auto">支持 PDF 或 Word 格式，<span class="text-red-500 font-semibold">文件大小不超过 10MB</span></p>
            </div>

            <div id="file-chosen" class="hidden text-center p-4 sm:p-6 animate-in zoom-in-95">
              <div class="w-12 sm:w-16 h-12 sm:h-16 bg-green-500 text-white rounded-lg sm:rounded-2xl flex items-center justify-center mx-auto mb-3 sm:mb-4 shadow-lg shadow-green-100">
                <svg class="w-6 sm:w-8 h-6 sm:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </div>
              <p id="file-name" class="text-gray-900 font-bold text-base sm:text-lg mb-1 truncate max-w-xs mx-auto"></p>
              <p id="file-size" class="text-gray-500 text-xs sm:text-sm mb-2"></p>
              <p class="text-green-600 font-bold text-xs sm:text-sm uppercase tracking-wider">文件已准备就绪</p>
            </div>

            <div id="file-error" class="hidden text-center p-4 sm:p-6 animate-in zoom-in-95">
              <div class="w-12 sm:w-16 h-12 sm:h-16 bg-red-500 text-white rounded-lg sm:rounded-2xl flex items-center justify-center mx-auto mb-3 sm:mb-4 shadow-lg shadow-red-100">
                <svg class="w-6 sm:w-8 h-6 sm:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              </div>
              <p id="error-name" class="text-gray-900 font-bold text-base sm:text-lg mb-2 truncate max-w-xs mx-auto"></p>
              <p id="error-message" class="text-red-600 font-semibold text-xs sm:text-sm mb-3"></p>
              <p class="text-red-500 font-bold text-xs sm:text-sm uppercase tracking-wider">文件不符合要求</p>
            </div>

            <input type="file" id="resume-input" name="resume_file" class="hidden" accept=".pdf,.doc,.docx" required />
          </label>

          <div class="flex justify-center mt-6 sm:mt-8">
            <button type="submit" id="submit-btn" class="w-full sm:w-auto px-8 sm:px-12 py-3 sm:py-4 bg-indigo-600 text-white text-base sm:text-lg font-bold rounded-lg sm:rounded-2xl shadow-xl shadow-indigo-100 hover:bg-indigo-700 hover:-translate-y-1 active:scale-95 transition-all duration-200">
              确认并上传
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  // 文件大小限制（10MB）
  const MAX_FILE_SIZE = 10 * 1024 * 1024; // 10MB in bytes
  const MAX_FILE_SIZE_MB = 10;

  const input = document.getElementById('resume-input');
  const placeholder = document.getElementById('upload-placeholder');
  const chosenDisplay = document.getElementById('file-chosen');
  const errorDisplay = document.getElementById('file-error');
  const fileNameDisplay = document.getElementById('file-name');
  const fileSizeDisplay = document.getElementById('file-size');
  const errorNameDisplay = document.getElementById('error-name');
  const errorMessageDisplay = document.getElementById('error-message');
  const dropZone = document.getElementById('drop-zone');
  const submitBtn = document.getElementById('submit-btn');
  const resumeForm = document.getElementById('resume-form');

  // 格式化文件大小
  function formatFileSize(bytes) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
  }

  // 验证文件
  function validateFile(file) {
    // 检查文件大小
    if (file.size > MAX_FILE_SIZE) {
      return {
        valid: false,
        error: `文件过大。您的文件大小为 ${formatFileSize(file.size)}，超过了 ${MAX_FILE_SIZE_MB}MB 的限制`
      };
    }
    return { valid: true };
  }

  // 处理文件选择
  function handleFileSelect(file) {
    const validation = validateFile(file);

    if (validation.valid) {
      // 显示成功状态
      placeholder.classList.add('hidden');
      errorDisplay.classList.add('hidden');
      chosenDisplay.classList.remove('hidden');
      fileNameDisplay.textContent = file.name;
      fileSizeDisplay.textContent = `文件大小：${formatFileSize(file.size)}`;
      dropZone.classList.remove('border-red-400', 'bg-red-50/30');
      dropZone.classList.add('border-green-400', 'bg-green-50/30');
      submitBtn.disabled = false;
    } else {
      // 显示错误状态
      placeholder.classList.add('hidden');
      chosenDisplay.classList.add('hidden');
      errorDisplay.classList.remove('hidden');
      errorNameDisplay.textContent = file.name;
      errorMessageDisplay.textContent = validation.error;
      dropZone.classList.remove('border-green-400', 'bg-green-50/30');
      dropZone.classList.add('border-red-400', 'bg-red-50/30');
      submitBtn.disabled = true;
      // 清空input
      input.value = '';
    }
  }

  // 监听文件选择
  input.addEventListener('change', (e) => {
    if (e.target.files.length > 0) {
      handleFileSelect(e.target.files[0]);
    }
  });

  // 拖拽上传支持
  ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
    dropZone.addEventListener(eventName, preventDefaults, false);
  });

  function preventDefaults(e) {
    e.preventDefault();
    e.stopPropagation();
  }

  ['dragenter', 'dragover'].forEach(eventName => {
    dropZone.addEventListener(eventName, highlight, false);
  });

  ['dragleave', 'drop'].forEach(eventName => {
    dropZone.addEventListener(eventName, unhighlight, false);
  });

  function highlight(e) {
    dropZone.classList.add('border-indigo-600', 'bg-indigo-100/20');
  }

  function unhighlight(e) {
    dropZone.classList.remove('border-indigo-600', 'bg-indigo-100/20');
  }

  dropZone.addEventListener('drop', handleDrop, false);

  function handleDrop(e) {
    const dt = e.dataTransfer;
    const files = dt.files;

    if (files.length > 0) {
      input.files = files;
      handleFileSelect(files[0]);
    }
  }

  // 表单提交前验证
  resumeForm.addEventListener('submit', (e) => {
    if (!input.files.length) {
      e.preventDefault();
      alert('请选择文件');
      return false;
    }

    const validation = validateFile(input.files[0]);
    if (!validation.valid) {
      e.preventDefault();
      alert(validation.error);
      return false;
    }
  });
</script>