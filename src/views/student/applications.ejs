<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8 lg:py-12">
  <!-- 页面标题 -->
  <div class="mb-8 sm:mb-12">
    <h1 class="text-3xl sm:text-4xl font-bold" style="color: var(--color-text-primary); margin-bottom: 0.5rem;">我的投递</h1>
    <p style="color: var(--color-text-tertiary); font-size: 0.95rem;">实时追踪投递状态，共 <span style="font-weight: 600; color: var(--color-text-secondary);"><%= applications.length %></span> 条记录</p>
  </div>

  <% if (applications.length === 0) { %>
  <!-- 空状态 -->
  <div class="card p-12 text-center">
    <div style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.6;">🎯</div>
    <h3 style="font-size: 1.125rem; margin-bottom: 0.5rem; color: var(--color-text-primary);">还未投递任何岗位</h3>
    <p style="color: var(--color-text-tertiary); margin-bottom: 1.5rem;">去浏览岗位列表，选择感兴趣的岗位投递吧</p>
    <a href="/student/jobs" class="inline-block px-6 py-3 text-sm font-semibold rounded-lg transition-all" 
       style="background-color: var(--color-primary); color: white; cursor: pointer;"
       onmouseover="this.style.backgroundColor='var(--color-primary-hover)'"
       onmouseout="this.style.backgroundColor='var(--color-primary)'">
      🔍 浏览岗位
    </a>
  </div>
  <% } else { %>

  <!-- 桌面版：列表 -->
  <div class="hidden md:block space-y-4">
    <% applications.forEach(function(app) { %>
    <div class="card p-6" style="padding: var(--spacing-card);">
      <div style="display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: center;">
        
        <!-- 左侧：岗位和时间 -->
        <div>
          <p style="color: var(--color-text-tertiary); font-size: 0.8rem; margin-bottom: 0.375rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500;">应聘岗位</p>
          <p style="font-weight: 600; color: var(--color-text-primary); font-size: 1.05rem; margin-bottom: 0.5rem;"><%= app.title %></p>
          <p class="mono" style="color: var(--color-text-tertiary); font-size: 0.85rem;">投递于 <%= new Date(app.created_at).toLocaleDateString('zh-CN') %></p>
        </div>

        <!-- 右侧：进度标签 -->
        <% if (app.status === 'pending') { %>
        <span class="badge badge-warning">⏳ 审核中</span>
        <% } else if (app.status === 'approved') { %>
        <span class="badge badge-success">✓ 已通过</span>
        <% } else if (app.status === 'rejected') { %>
        <span class="badge badge-error">✕ 已拒绝</span>
        <% } %>
        
      </div>
    </div>
    <% }) %>
  </div>

  <!-- 移动版：卡片视图 -->
  <div class="md:hidden space-y-4">
    <% applications.forEach(function(app) { %>
    <div class="card p-5" style="padding: 1.25rem;">
      <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
        
        <!-- 岗位信息 -->
        <div style="flex: 1; min-width: 0;">
          <p style="color: var(--color-text-tertiary); font-size: 0.8rem; margin-bottom: 0.375rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500;">应聘岗位</p>
          <p style="font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.5rem; word-break: break-word;"><%= app.title %></p>
          <p class="mono" style="color: var(--color-text-tertiary); font-size: 0.85rem;">
            <%= new Date(app.created_at).toLocaleDateString('zh-CN') %>
          </p>
        </div>

        <!-- 状态标签 -->
        <div style="flex-shrink: 0;">
          <% if (app.status === 'pending') { %>
          <span class="badge badge-warning">⏳ 审核中</span>
          <% } else if (app.status === 'approved') { %>
          <span class="badge badge-success">✓ 已通过</span>
          <% } else if (app.status === 'rejected') { %>
          <span class="badge badge-error">✕ 已拒绝</span>
          <% } %>
        </div>
        
      </div>
    </div>
    <% }) %>
  </div>

  <% } %>
</div>