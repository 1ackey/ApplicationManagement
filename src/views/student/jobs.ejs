<div class="max-w-6xl mx-auto">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">岗位列表</h1>
    <p class="text-gray-600 mt-2">浏览并投递感兴趣的岗位</p>
  </div>

  <% if (!jobs || jobs.length === 0) { %>
  <!-- Empty State -->
  <div class="bg-white rounded-xl border border-slate-200/80 shadow-sm py-12 text-center">
    <p class="text-5xl mb-4">🔍</p>
    <h3 class="text-xl font-bold text-slate-900 mb-2">暂无岗位</h3>
    <p class="text-slate-500">建议稍后再来查看</p>
  </div>
  <% } else { %>
  <!-- Jobs Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% jobs.forEach(function(job){ %>
    <div
      class="bg-white rounded-xl border border-slate-200/80 shadow-sm overflow-hidden
             hover:shadow-md hover:-translate-y-0.5 active:scale-[0.98]
             cursor-pointer transition-all duration-200 ease-in-out">
      <a href="/student/jobs/<%= job.id %>" class="no-underline block px-5 py-4">
          <!-- Company Badge -->
          <div class="mb-3">
            <span class="inline-block bg-blue-100 text-blue-800 text-xs font-semibold px-3 py-1 rounded-full">
              🏢 <%= job.company_name %>
            </span>
          </div>

          <!-- Job Title -->
          <h3 class="text-lg font-bold text-gray-900 mb-2 line-clamp-2">
            <%= job.title %>
          </h3>

          <!-- Job Description Preview -->
          <p class="text-gray-600 text-sm mb-4 line-clamp-3">
            <%= (job.description || '暂无描述').substring(0, 100) %>
          </p>

          <!-- Footer -->
          <div class="border-t border-gray-100 pt-4 mt-2 flex items-center justify-between text-sm">
            <span class="text-xs text-slate-400">
              点击卡片查看详情
            </span>
            <span class="inline-flex items-center text-blue-600 hover:text-blue-700 font-semibold transition-colors duration-200">
              查看详情 & 投递 
              <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 10l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
              </svg>
            </span>
          </div>
      </a>
    </div>
    <% }) %>
  </div>

  <!-- Stats Section -->
  <div class="mt-12 pt-8 border-t border-gray-200">
    <p class="text-center text-gray-600">
      💼 共有 <span class="font-bold text-blue-600"><%= jobs.length %></span> 个岗位等你投递
    </p>
  </div>
  <% } %>
</div>
