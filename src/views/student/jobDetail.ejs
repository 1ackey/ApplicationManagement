<div class="max-w-4xl mx-auto">
  <!-- Back Link -->
  <a
    href="/student/jobs"
    class="inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-700 hover:underline
           transition-all duration-200 ease-in-out mb-6">
    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"></path>
    </svg>
    返回岗位列表
  </a>

  <!-- Job Header -->
  <div class="bg-white rounded-xl border border-slate-200/80 shadow-sm mb-6
              hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 ease-in-out">
    <div class="px-6 py-5">
      <div class="flex justify-between items-start">
        <div>
          <h1 class="text-3xl font-bold text-slate-900 mb-2"><%= job.title %></h1>
          <p class="text-sm text-slate-500">
            公司：
            <span class="font-semibold text-slate-900"><%= job.company_name %></span>
          </p>
        </div>
        <div class="ml-4">
          <% if (hasResume) { %>
          <form method="post" action="/student/jobs/<%= job.id %>/apply">
            <button
              type="submit"
              class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium
                     rounded-lg bg-blue-600 text-white
                     hover:bg-blue-700 active:bg-blue-800 active:scale-95
                     focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2
                     transition-all duration-200 ease-in-out">
              投递岗位
            </button>
          </form>
          <% } else { %>
          <div class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium rounded-lg bg-gray-300 text-gray-600 cursor-not-allowed" title="请先上传简历">
            投递岗位
          </div>
          <% } %>
        </div>
      </div>
      <% if (!hasResume) { %>
      <div class="mt-4 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
        <p class="text-sm text-yellow-800">
          ⚠️ 您还未上传简历，请先
          <a href="/student/profile" class="font-semibold text-yellow-900 hover:underline">上传简历</a>
          才能投递岗位
        </p>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Job Details -->
  <div class="grid grid-cols-1 gap-6">
    <!-- Description -->
    <div class="bg-white rounded-xl border border-slate-200/80 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 ease-in-out">
      <div class="px-6 py-5">
        <h3 class="text-base font-semibold text-slate-900 mb-3">岗位描述</h3>
        <p class="text-slate-700 leading-relaxed whitespace-pre-wrap text-sm">
          <%= job.description || '暂无描述' %>
        </p>
      </div>
    </div>

    <!-- Requirements -->
    <div class="bg-white rounded-xl border border-slate-200/80 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 ease-in-out">
      <div class="px-6 py-5">
        <h3 class="text-base font-semibold text-slate-900 mb-3">岗位要求</h3>
        <p class="text-slate-700 leading-relaxed whitespace-pre-wrap text-sm">
          <%= job.requirement || '暂无要求' %>
        </p>
      </div>
    </div>
  </div>

  
</div>

