<div class="min-h-[calc(100vh-6rem)] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="w-full max-w-md space-y-6">
    <!-- Header -->
    <div class="text-center space-y-1">
      <h2 class="text-3xl font-bold text-slate-900 tracking-tight">登录</h2>
      <p class="text-sm text-slate-500">欢迎使用校企合作投递系统</p>
    </div>

    <!-- Error Alert -->
    <% if (error) { %>
    <div class="rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700 flex items-start space-x-2">
      <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
      </svg>
      <span><%= error %></span>
    </div>
    <% } %>

    <!-- Login Card -->
    <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 ease-in-out">
      <div class="px-6 py-6 space-y-5">
        <form method="post" action="/login" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">用户名</label>
            <input
              type="text"
              name="username"
              required
              placeholder="请输入用户名"
              class="block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm
                     placeholder-slate-400
                     focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500
                     transition-all duration-200 ease-in-out"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">密码</label>
            <input
              type="password"
              name="password"
              required
              placeholder="请输入密码"
              class="block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm
                     placeholder-slate-400
                     focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500
                     transition-all duration-200 ease-in-out"
            />
          </div>
          <button
            type="submit"
            class="w-full inline-flex items-center justify-center px-4 py-2.5
                   rounded-lg text-sm font-medium
                   bg-blue-600 text-white
                   hover:bg-blue-700
                   active:bg-blue-800 active:scale-95
                   focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2
                   transition-all duration-200 ease-in-out">
            登录
          </button>
        </form>

        <div class="pt-3 border-t border-slate-100 text-xs text-slate-500">
          默认管理员账号：<span class="font-mono text-slate-700">admin / admin123</span>
        </div>
      </div>
    </div>

    <!-- Register Link -->
    <div class="text-center text-sm text-slate-500">
      没有账号？
      <a href="/register" class="font-medium text-blue-600 hover:text-blue-700 hover:underline transition-colors duration-200">
        去注册
      </a>
    </div>
  </div>
</div>

