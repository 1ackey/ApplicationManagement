<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8 lg:py-12">
  <!-- 页面标题 -->
  <div class="mb-8 sm:mb-12">
    <div class="mb-4 flex justify-between items-center">
      <a href="/admin/dashboard" class="text-indigo-600 hover:text-indigo-700 text-sm font-medium">← 返回统计面板</a>
      <% if (applications.some(a => a.resume_url)) { %>
      <a href="/admin/jobs/<%= job.id %>/download" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-lg transition-colors">
        ↓ 下载本岗位简历
      </a>
      <% } %>
    </div>
    <h1 class="text-3xl sm:text-4xl font-bold" style="color: var(--color-text-primary); margin-bottom: 0.5rem;"><%= job.title %></h1>
    <div style="display: flex; gap: 1rem; margin-top: 0.5rem;">
      <p style="color: var(--color-text-secondary); font-size: 0.95rem;">公司：<span style="font-weight: 600;"><%= job.company_name %></span></p>
      <p style="color: var(--color-text-tertiary); font-size: 0.95rem;">共 <span class="font-semibold" style="color: var(--color-text-secondary);"><%= applications.length %></span> 位学生申请</p>
    </div>
  </div>

  <!-- 状态统计 -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
    <div class="card p-4 sm:p-6">
      <p style="color: var(--color-text-tertiary); font-size: 0.875rem; margin-bottom: 0.5rem; font-weight: 600;">待审核</p>
      <p class="text-2xl sm:text-3xl font-bold" style="color: var(--color-orange); margin-bottom: 0.5rem;"><%= groupedByStatus.pending.length %></p>
      <div class="w-full h-1.5 bg-gray-100 rounded-full overflow-hidden">
        <div class="h-full bg-orange-400" style="width: <%= (groupedByStatus.pending.length / applications.length * 100 || 0) %>%"></div>
      </div>
    </div>
    <div class="card p-4 sm:p-6">
      <p style="color: var(--color-text-tertiary); font-size: 0.875rem; margin-bottom: 0.5rem; font-weight: 600;">已通过</p>
      <p class="text-2xl sm:text-3xl font-bold" style="color: var(--color-success); margin-bottom: 0.5rem;"><%= groupedByStatus.approved.length %></p>
      <div class="w-full h-1.5 bg-gray-100 rounded-full overflow-hidden">
        <div class="h-full bg-emerald-400" style="width: <%= (groupedByStatus.approved.length / applications.length * 100 || 0) %>%"></div>
      </div>
    </div>
    <div class="card p-4 sm:p-6">
      <p style="color: var(--color-text-tertiary); font-size: 0.875rem; margin-bottom: 0.5rem; font-weight: 600;">已拒绝</p>
      <p class="text-2xl sm:text-3xl font-bold" style="color: var(--color-error); margin-bottom: 0.5rem;"><%= groupedByStatus.rejected.length %></p>
      <div class="w-full h-1.5 bg-gray-100 rounded-full overflow-hidden">
        <div class="h-full bg-rose-400" style="width: <%= (groupedByStatus.rejected.length / applications.length * 100 || 0) %>%"></div>
      </div>
    </div>
  </div>

  <% if (applications.length === 0) { %>
  <!-- 空状态 -->
  <div class="card p-12 text-center">
    <div style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.6;">📨</div>
    <h3 style="font-size: 1.125rem; margin-bottom: 0.5rem; color: var(--color-text-primary);">暂无申请</h3>
    <p style="color: var(--color-text-tertiary);">还没有学生申请该岗位</p>
  </div>
  <% } else { %>

  <!-- 待审核申请 -->
  <% if (groupedByStatus.pending.length > 0) { %>
  <div style="margin-bottom: 3rem;">
    <h3 style="font-size: 1.125rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 1.5rem;">⏳ 待审核申请 (<%= groupedByStatus.pending.length %>)</h3>
    
    <!-- 桌面版 -->
    <div class="hidden md:block card overflow-hidden">
      <div style="border: 1px solid var(--color-border); border-radius: var(--radius-lg);">
        <% groupedByStatus.pending.forEach(function(app, idx) { %>
        <div class="<%= idx > 0 ? 'border-t' : '' %>" style="<%= idx > 0 ? 'border-color: var(--color-border); border-top: 1px solid;' : '' %>">
          <div style="padding: var(--spacing-card); display: grid; grid-template-columns: 2fr 1.5fr 1.2fr auto; gap: 2rem; align-items: center;" 
               onmouseover="this.style.backgroundColor='rgba(59, 130, 246, 0.02)'" 
               onmouseout="this.style.backgroundColor='transparent'">
            
            <!-- 学生信息 -->
            <div>
              <p style="color: var(--color-text-tertiary); font-size: 0.8rem; margin-bottom: 0.375rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500;">申请人</p>
              <p style="font-weight: 600; color: var(--color-text-primary);"><%= app.name || '未填写' %></p>
            </div>

            <!-- 简历状态 -->
            <div>
              <p style="color: var(--color-text-tertiary); font-size: 0.8rem; margin-bottom: 0.375rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500;">简历</p>
              <% if (app.resume_url) { %>
              <a href="<%= app.resume_url %>" target="_blank" class="badge badge-success" style="cursor: pointer;">
                ✓ 已上传
              </a>
              <% } else { %>
              <span style="display: inline-flex; padding: 0.375rem 0.75rem; background-color: var(--color-border-light); color: var(--color-text-tertiary); border-radius: calc(var(--radius-default) / 2); font-size: 0.875rem;">
                未上传
              </span>
              <% } %>
            </div>

            <!-- 时间 -->
            <div>
              <p style="color: var(--color-text-tertiary); font-size: 0.8rem; margin-bottom: 0.375rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500;">时间</p>
              <p class="mono" style="color: var(--color-text-primary); font-size: 0.9rem;"><%= new Date(app.created_at).toLocaleDateString('zh-CN') %></p>
            </div>

            <!-- 操作按钮 -->
            <div style="display: flex; gap: 0.75rem;">
              <form method="post" action="/admin/applications/<%= app.id %>/review" class="inline">
                <input type="hidden" name="status" value="approved" />
                <button type="submit" class="px-3 py-2 font-semibold text-sm rounded-lg transition-all" 
                  style="background-color: var(--color-success-bg); color: var(--color-success); border: 1px solid var(--color-success-border); cursor: pointer;"
                  onmouseover="this.style.backgroundColor='rgba(16, 185, 129, 0.15)'"
                  onmouseout="this.style.backgroundColor='var(--color-success-bg)'">
                  ✓ 通过
                </button>
              </form>
              <form method="post" action="/admin/applications/<%= app.id %>/review" class="inline">
                <input type="hidden" name="status" value="rejected" />
                <button type="submit" class="px-3 py-2 font-semibold text-sm rounded-lg transition-all" 
                  style="background-color: var(--color-error-bg); color: var(--color-error); border: 1px solid var(--color-error-border); cursor: pointer;"
                  onmouseover="this.style.backgroundColor='rgba(239, 68, 68, 0.15)'"
                  onmouseout="this.style.backgroundColor='var(--color-error-bg)'">
                  ✕ 拒绝
                </button>
              </form>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- 移动版 -->
    <div class="md:hidden space-y-3">
      <% groupedByStatus.pending.forEach(function(app) { %>
      <div class="card p-4">
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
          <div style="width: 2rem; height: 2rem; border-radius: 50%; background-color: var(--color-info-bg); display: flex; align-items: center; justify-content: center; font-weight: 600; color: var(--color-info);">
            <%= (app.name || '未').substring(0,1) %>
          </div>
          <div>
            <p style="font-weight: 600; color: var(--color-text-primary);"><%= app.name || '未填写' %></p>
            <p class="mono" style="color: var(--color-text-tertiary); font-size: 0.85rem;"><%= new Date(app.created_at).toLocaleDateString('zh-CN') %></p>
          </div>
        </div>
        <div style="display: flex; gap: 0.75rem; margin-bottom: 1rem;">
          <form method="post" action="/admin/applications/<%= app.id %>/review" class="flex-1">
            <input type="hidden" name="status" value="approved" />
            <button type="submit" class="w-full px-4 py-2 font-semibold text-sm rounded-lg transition-all" 
              style="background-color: var(--color-success-bg); color: var(--color-success); border: 1px solid var(--color-success-border); cursor: pointer;">
              ✓ 通过
            </button>
          </form>
          <form method="post" action="/admin/applications/<%= app.id %>/review" class="flex-1">
            <input type="hidden" name="status" value="rejected" />
            <button type="submit" class="w-full px-4 py-2 font-semibold text-sm rounded-lg transition-all" 
              style="background-color: var(--color-error-bg); color: var(--color-error); border: 1px solid var(--color-error-border); cursor: pointer;">
              ✕ 拒绝
            </button>
          </form>
        </div>
        <% if (app.resume_url) { %>
        <a href="<%= app.resume_url %>" download target="_blank" class="block w-full px-4 py-2 font-semibold text-sm rounded-lg transition-all text-center" 
           style="background-color: var(--color-info-bg); color: var(--color-info); border: 1px solid var(--color-info-border); cursor: pointer;">
          ↓ 下载简历
        </a>
        <% } %>
      </div>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- 已通过申请 -->
  <% if (groupedByStatus.approved.length > 0) { %>
  <div style="margin-bottom: 3rem;">
    <h3 style="font-size: 1.125rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 1.5rem;">✓ 已通过申请 (<%= groupedByStatus.approved.length %>)</h3>
    
    <div class="hidden md:block card overflow-hidden">
      <div style="border: 1px solid var(--color-border); border-radius: var(--radius-lg);">
        <% groupedByStatus.approved.forEach(function(app, idx) { %>
        <div class="<%= idx > 0 ? 'border-t' : '' %>" style="<%= idx > 0 ? 'border-color: var(--color-border); border-top: 1px solid;' : '' %>">
          <div style="padding: var(--spacing-card); display: grid; grid-template-columns: 2fr 1.5fr 1.2fr auto; gap: 2rem; align-items: center; background-color: rgba(16, 185, 129, 0.02);">
            <div>
              <p style="font-weight: 600; color: var(--color-text-primary);"><%= app.name || '未填写' %></p>
            </div>
            <div>
              <% if (app.resume_url) { %>
              <span class="badge badge-success">✓ 已上传</span>
              <% } else { %>
              <span style="display: inline-flex; padding: 0.375rem 0.75rem; background-color: var(--color-border-light); color: var(--color-text-tertiary); border-radius: calc(var(--radius-default) / 2); font-size: 0.875rem;">
                未上传
              </span>
              <% } %>
            </div>
            <div>
              <p class="mono" style="color: var(--color-text-primary); font-size: 0.9rem;"><%= new Date(app.created_at).toLocaleDateString('zh-CN') %></p>
            </div>
            <div>
              <span class="badge badge-success">已通过</span>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <div class="md:hidden space-y-2">
      <% groupedByStatus.approved.forEach(function(app) { %>
      <div class="card p-4" style="background-color: rgba(16, 185, 129, 0.02);">
        <div style="display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
          <div>
            <p style="font-weight: 600; color: var(--color-text-primary);"><%= app.name || '未填写' %></p>
            <p class="mono" style="color: var(--color-text-tertiary); font-size: 0.85rem;"><%= new Date(app.created_at).toLocaleDateString('zh-CN') %></p>
          </div>
          <span class="badge badge-success">已通过</span>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- 已拒绝申请 -->
  <% if (groupedByStatus.rejected.length > 0) { %>
  <div>
    <h3 style="font-size: 1.125rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 1.5rem;">✕ 已拒绝申请 (<%= groupedByStatus.rejected.length %>)</h3>
    
    <div class="hidden md:block card overflow-hidden">
      <div style="border: 1px solid var(--color-border); border-radius: var(--radius-lg);">
        <% groupedByStatus.rejected.forEach(function(app, idx) { %>
        <div class="<%= idx > 0 ? 'border-t' : '' %>" style="<%= idx > 0 ? 'border-color: var(--color-border); border-top: 1px solid;' : '' %>">
          <div style="padding: var(--spacing-card); display: grid; grid-template-columns: 2fr 1.5fr 1.2fr auto; gap: 2rem; align-items: center; background-color: rgba(239, 68, 68, 0.02);">
            <div>
              <p style="font-weight: 600; color: var(--color-text-primary);"><%= app.name || '未填写' %></p>
            </div>
            <div>
              <% if (app.resume_url) { %>
              <span class="badge badge-info">简历已上传</span>
              <% } else { %>
              <span style="display: inline-flex; padding: 0.375rem 0.75rem; background-color: var(--color-border-light); color: var(--color-text-tertiary); border-radius: calc(var(--radius-default) / 2); font-size: 0.875rem;">
                未上传
              </span>
              <% } %>
            </div>
            <div>
              <p class="mono" style="color: var(--color-text-primary); font-size: 0.9rem;"><%= new Date(app.created_at).toLocaleDateString('zh-CN') %></p>
            </div>
            <div>
              <span class="badge badge-error">已拒绝</span>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <div class="md:hidden space-y-2">
      <% groupedByStatus.rejected.forEach(function(app) { %>
      <div class="card p-4" style="background-color: rgba(239, 68, 68, 0.02);">
        <div style="display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
          <div>
            <p style="font-weight: 600; color: var(--color-text-primary);"><%= app.name || '未填写' %></p>
            <p class="mono" style="color: var(--color-text-tertiary); font-size: 0.85rem;"><%= new Date(app.created_at).toLocaleDateString('zh-CN') %></p>
          </div>
          <span class="badge badge-error">已拒绝</span>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <% } %>

  <% } %>
</div>

<style>
  .badge {
    display: inline-flex;
    padding: 0.375rem 0.75rem;
    border-radius: calc(var(--radius-default) / 2);
    font-size: 0.875rem;
    font-weight: 600;
    align-items: center;
    gap: 0.375rem;
  }

  .badge-success {
    background-color: var(--color-success-bg);
    color: var(--color-success);
    border: 1px solid var(--color-success-border);
  }

  .badge-error {
    background-color: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error-border);
  }

  .badge-info {
    background-color: var(--color-info-bg);
    color: var(--color-info);
    border: 1px solid var(--color-info-border);
  }
</style>
