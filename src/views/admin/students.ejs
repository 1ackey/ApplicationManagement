<div class="max-w-6xl mx-auto px-2 sm:px-4 lg:px-8 py-4 sm:py-6 lg:py-8">
  <!-- Header -->
  <div class="mb-6 sm:mb-8">
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">📚 学生简历库</h1>
    <p class="text-sm text-gray-500 mt-1 sm:mt-2">全部学生的信息和简历</p>
  </div>

  <% if (students.length === 0) { %>
  <!-- Empty State -->
  <div class="bg-white border border-gray-100 rounded-lg sm:rounded-xl shadow-sm p-8 sm:p-12 text-center">
    <p class="text-4xl sm:text-5xl mb-4">👥</p>
    <h3 class="text-lg sm:text-xl font-bold text-gray-900 mb-1">暂无学生</h3>
    <p class="text-sm text-gray-500">还没有学生注册</p>
  </div>
  <% } else { %>
  
  <!-- Desktop Table View -->
  <div class="hidden md:block bg-white border border-gray-100 rounded-lg lg:rounded-xl shadow-sm overflow-hidden mb-8">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-gray-50/50 border-b border-gray-100">
            <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-left">用户名</th>
            <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-left">姓名</th>
            <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-left">简历</th>
            <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-center">状态</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% students.forEach(function(s){ %>
          <tr class="hover:bg-gray-50/50 transition-colors duration-150">
            <td class="px-6 py-5">
              <span class="inline-flex px-3 py-1 bg-blue-100 text-blue-700 text-xs font-semibold rounded-full"><%= s.username %></span>
            </td>
            <td class="px-6 py-5 text-sm font-medium text-gray-900"><%= s.name || '-' %></td>
            <td class="px-6 py-5">
              <% if (s.resume_url) { %>
              <a href="<%= s.resume_url %>" target="_blank" class="inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                查看简历
              </a>
              <% } else { %>
              <span class="text-xs text-gray-500">暂无</span>
              <% } %>
            </td>
            <td class="px-6 py-5 text-center">
              <% if (s.resume_url) { %>
              <span class="inline-flex items-center px-3 py-1 bg-emerald-50 text-emerald-700 text-xs font-semibold border border-emerald-200 rounded-full">
                ✅ 已完成
              </span>
              <% } else { %>
              <span class="inline-flex items-center px-3 py-1 bg-amber-50 text-amber-700 text-xs font-semibold border border-amber-200 rounded-full">
                ⏳ 未完成
              </span>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Mobile Card View -->
  <div class="md:hidden space-y-3 mb-8">
    <% students.forEach(function(s){ %>
    <div class="bg-white border border-gray-100 rounded-lg shadow-sm p-4">
      <div class="mb-3">
        <span class="inline-flex px-2.5 py-1 bg-blue-100 text-blue-700 text-xs font-semibold rounded-full"><%= s.username %></span>
        <p class="text-base font-semibold text-gray-900 mt-2"><%= s.name || '-' %></p>
      </div>

      <div class="flex items-center justify-between mb-3 pb-3 border-b border-gray-100">
        <p class="text-xs font-semibold text-gray-500 uppercase">状态</p>
        <% if (s.resume_url) { %>
        <span class="inline-flex items-center px-2.5 py-1 bg-emerald-50 text-emerald-700 text-xs font-semibold border border-emerald-200 rounded-full">
          ✅ 已完成
        </span>
        <% } else { %>
        <span class="inline-flex items-center px-2.5 py-1 bg-amber-50 text-amber-700 text-xs font-semibold border border-amber-200 rounded-full">
          ⏳ 未完成
        </span>
        <% } %>
      </div>

      <% if (s.resume_url) { %>
      <a href="<%= s.resume_url %>" target="_blank" class="w-full inline-flex items-center justify-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-lg transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
        查看简历
      </a>
      <% } %>
    </div>
    <% }) %>
  </div>

  <!-- Summary Stats -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
    <div class="bg-white border border-gray-100 rounded-lg shadow-sm p-4 sm:p-6 text-center">
      <p class="text-xs sm:text-sm text-gray-500 font-semibold mb-2">总学生数</p>
      <p class="text-3xl sm:text-4xl font-bold text-blue-600"><%= students.length %></p>
    </div>
    <div class="bg-white border border-gray-100 rounded-lg shadow-sm p-4 sm:p-6 text-center">
      <p class="text-xs sm:text-sm text-gray-500 font-semibold mb-2">已上传简历</p>
      <p class="text-3xl sm:text-4xl font-bold text-emerald-600"><%= students.filter(s => s.resume_url).length %></p>
    </div>
    <div class="bg-white border border-gray-100 rounded-lg shadow-sm p-4 sm:p-6 text-center">
      <p class="text-xs sm:text-sm text-gray-500 font-semibold mb-2">未上传简历</p>
      <p class="text-3xl sm:text-4xl font-bold text-amber-600"><%= students.filter(s => !s.resume_url).length %></p>
    </div>
  </div>
  <% } %>
</div>

