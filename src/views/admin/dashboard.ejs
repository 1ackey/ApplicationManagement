<div class="max-w-7xl mx-auto px-2 sm:px-4 lg:px-8 py-4 sm:py-6 lg:py-10">
  <div class="mb-6 sm:mb-10 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-2">
    <div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">统计面板</h1>
      <p class="text-xs sm:text-base text-gray-500 mt-1 sm:mt-2 font-medium">系统运行概览</p>
    </div>
    <div class="hidden md:block text-xs text-gray-400 font-mono">
      LAST UPDATED: <%= new Date().toLocaleTimeString() %>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-3 sm:gap-4 lg:gap-6 mb-8 sm:mb-12">
    
    <div class="relative overflow-hidden bg-slate-900 rounded-lg sm:rounded-2xl p-4 sm:p-6 shadow-xl group">
      <div class="relative z-10">
        <p class="text-slate-400 text-xs font-bold uppercase tracking-wider mb-1">总岗位数</p>
        <div class="flex items-baseline gap-2">
          <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white"><%= stats.total_jobs %></h2>
          <span class="text-slate-500 text-xs font-bold">个</span>
        </div>
      </div>
      <div class="absolute -right-4 -bottom-4 text-slate-800 transform rotate-12 group-hover:scale-110 transition-transform duration-500">
        <svg class="w-16 sm:w-20 h-16 sm:h-20" fill="currentColor" viewBox="0 0 24 24"><path d="M20 6h-4V4c0-1.11-.89-2-2-2h-4c-1.11 0-2 .89-2 2v2H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-6 0h-4V4h4v2z"/></svg>
      </div>
    </div>

    <div class="relative overflow-hidden bg-white border border-gray-100 rounded-lg sm:rounded-2xl p-4 sm:p-6 shadow-sm group">
      <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-1">总投递人次</p>
      <div class="flex items-baseline gap-2">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-emerald-600"><%= stats.total_apps %></h2>
        <span class="text-gray-400 text-xs font-bold">次</span>
      </div>
      <div class="mt-3 flex items-center text-xs font-bold text-emerald-500">
        <span class="bg-emerald-50 px-2 py-0.5 rounded-full">ACTIVE</span>
      </div>
    </div>

    <div class="relative overflow-hidden bg-white border border-gray-100 rounded-lg sm:rounded-2xl p-4 sm:p-6 shadow-sm">
      <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-1 text-amber-500">待处理</p>
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-gray-900"><%= stats.pending %></h2>
      <div class="mt-3 h-1 sm:h-1.5 w-full bg-gray-100 rounded-full overflow-hidden">
        <div class="h-full bg-amber-400 rounded-full" style="width: <%= (stats.pending / stats.total_apps * 100).toFixed(0) %>%"></div>
      </div>
    </div>

    <div class="relative overflow-hidden bg-white border border-gray-100 rounded-lg sm:rounded-2xl p-4 sm:p-6 shadow-sm hidden sm:block">
      <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-1">已批准</p>
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-gray-900"><%= stats.approved %></h2>
    </div>

    <div class="relative overflow-hidden bg-white border border-gray-100 rounded-lg sm:rounded-2xl p-4 sm:p-6 shadow-sm hidden lg:block">
      <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-1 text-rose-500">已拒绝</p>
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-gray-900"><%= stats.rejected %></h2>
      <div class="absolute right-4 bottom-4 opacity-5">
        <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
      </div>
    </div>

  </div>

  <!-- Job Stats Table -->
  <div class="bg-white border border-gray-100 shadow-[0_8px_30px_rgb(0,0,0,0.04)] rounded-lg sm:rounded-2xl overflow-hidden">
    <div class="px-4 sm:px-6 lg:px-8 py-4 sm:py-6 border-b border-gray-100 bg-gray-50/50">
      <h3 class="text-lg sm:text-xl font-bold text-gray-900">岗位投递统计</h3>
    </div>
    
    <!-- Desktop View -->
    <div class="hidden md:block overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="text-xs font-bold text-gray-400 uppercase tracking-wider border-b border-gray-100">
            <th class="px-6 py-4 text-left">岗位信息</th>
            <th class="px-6 py-4 text-right">投递数</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% jobStats.forEach(function(row, index){ %>
          <tr class="group hover:bg-slate-50/80 transition-all duration-200">
            <td class="px-6 py-6">
              <div class="flex items-center gap-4">
                <span class="text-xs font-mono text-gray-400">#<%= index + 1 %></span>
                <div>
                  <div class="text-gray-900 font-bold text-base group-hover:text-indigo-600 transition-colors"><%= row.title %></div>
                  <div class="text-gray-500 text-xs mt-0.5 font-medium"><%= row.company_name %></div>
                </div>
              </div>
            </td>
            <td class="px-6 py-6 text-right">
              <div class="inline-flex items-center gap-4">
                <div class="flex flex-col items-end">
                  <span class="text-gray-900 font-bold"><%= row.count %></span>
                  <span class="text-xs text-gray-400 font-bold uppercase tracking-tighter">人</span>
                </div>
                <div class="w-12 h-6 flex items-end gap-0.5">
                   <div class="bg-indigo-100 w-1.5 h-1/2 rounded-full"></div>
                   <div class="bg-indigo-200 w-1.5 h-3/4 rounded-full"></div>
                   <div class="bg-indigo-600 w-1.5 h-full rounded-full animate-pulse"></div>
                </div>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Mobile View -->
    <div class="md:hidden space-y-2">
      <% jobStats.forEach(function(row, index){ %>
      <div class="p-4 border-b border-gray-100 hover:bg-gray-50/50 transition-colors">
        <div class="flex items-start justify-between gap-3 mb-2">
          <div>
            <p class="text-base font-bold text-gray-900 break-words"><%= row.title %></p>
            <p class="text-xs text-gray-500 mt-1"><%= row.company_name %></p>
          </div>
          <div class="text-right flex-shrink-0">
            <p class="text-lg sm:text-xl font-bold text-gray-900"><%= row.count %></p>
            <p class="text-xs text-gray-400">投递人数</p>
          </div>
        </div>
        <div class="w-full h-1.5 bg-gray-100 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-indigo-300 to-indigo-600" style="width: <%= Math.min(100, row.count * 10) %>%"></div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</div>