<div class="min-h-screen bg-gray-50/50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10">
      <div>
        <div class="flex items-center gap-3">
          <div class="h-8 w-1.5 bg-indigo-600 rounded-full"></div>
          <h1 class="text-3xl font-black text-gray-900 tracking-tight">控制中心</h1>
        </div>
        <p class="text-gray-500 mt-2 flex items-center gap-2">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          系统运行概览 · <span class="font-mono text-xs uppercase tracking-widest"><%= new Date().toLocaleTimeString() %></span>
        </p>
      </div>

      <a href="/admin/applications/download-all" 
         class="group relative inline-flex items-center justify-center gap-3 px-6 py-3 bg-slate-900 text-white font-bold rounded-2xl transition-all hover:bg-indigo-600 hover:ring-4 hover:ring-indigo-100 shadow-xl shadow-slate-200">
        <svg class="w-5 h-5 transition-transform group-hover:-translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
        </svg>
        <span>打包下载全部简历</span>
      </a>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-12">
      
      <div class="col-span-2 lg:col-span-1 bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">总岗位</p>
        <div class="flex items-end justify-between">
          <h2 class="text-4xl font-black text-slate-900"><%= stats.total_jobs %></h2>
          <div class="p-2 bg-slate-50 rounded-lg text-slate-400">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20 6h-4V4c0-1.11-.89-2-2-2h-4c-1.11 0-2 .89-2 2v2H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zM10 4h4v2h-4V4z"/></svg>
          </div>
        </div>
      </div>

      <div class="bg-indigo-50/50 p-6 rounded-[2rem] border border-indigo-100 shadow-sm">
        <p class="text-xs font-bold text-indigo-400 uppercase tracking-widest mb-4">投递人次</p>
        <h2 class="text-4xl font-black text-indigo-600"><%= stats.total_apps %></h2>
        <div class="mt-2 text-[10px] font-bold text-indigo-400">活跃中 ↑</div>
      </div>

      <div class="bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm">
        <p class="text-xs font-bold text-amber-500 uppercase tracking-widest mb-4">待处理</p>
        <h2 class="text-4xl font-black text-gray-900"><%= stats.pending %></h2>
        <div class="mt-4 w-full bg-gray-100 h-1.5 rounded-full overflow-hidden">
          <div class="h-full bg-amber-400" style="width: <%= (stats.pending / stats.total_apps * 100).toFixed(0) %>%"></div>
        </div>
      </div>

      <div class="bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm">
        <p class="text-xs font-bold text-emerald-500 uppercase tracking-widest mb-4">已批准</p>
        <h2 class="text-4xl font-black text-gray-900"><%= stats.approved %></h2>
      </div>

      <div class="bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm">
        <p class="text-xs font-bold text-rose-500 uppercase tracking-widest mb-4">已拒绝</p>
        <h2 class="text-4xl font-black text-gray-900"><%= stats.rejected %></h2>
      </div>
    </div>

    <div class="bg-white rounded-[2.5rem] border border-gray-100 shadow-xl shadow-gray-200/50 overflow-hidden">
      <div class="px-8 py-6 border-b border-gray-50 flex items-center justify-between">
        <h3 class="text-xl font-bold text-gray-900">岗位实时统计</h3> 
      </div>
      
      <div class="hidden md:block">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="text-[11px] font-black text-gray-400 uppercase tracking-[0.2em] bg-gray-50/50">
              <th class="px-8 py-5">职位</th>
              <th class="px-8 py-5 text-right">投递人次</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% jobStats.forEach(function(row, index){ %>
            <tr class="group hover:bg-indigo-50/30 transition-all cursor-pointer" onclick="window.location.href='/admin/jobs/<%= row.id %>/applications'">
              <td class="px-8 py-6">
                <div class="flex items-center gap-6">
                  <span class="text-2xl font-black text-gray-100 group-hover:text-indigo-200 transition-colors">0<%= index + 1 %></span>
                  <div>
                    <div class="text-gray-900 font-bold text-lg group-hover:text-indigo-600 transition-colors"><%= row.title %></div>
                    <div class="text-gray-400 text-sm font-medium mt-0.5"><%= row.company_name %></div>
                  </div>
                </div>
              </td>
              <td class="px-8 py-6 text-right">
                <div class="inline-flex items-baseline gap-1">
                  <span class="text-2xl font-black text-gray-900"><%= row.count %></span>

                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="md:hidden divide-y divide-gray-50 px-4">
        <% jobStats.forEach(function(row, index){ %>
        <div class="py-6 active:scale-95 transition-transform" onclick="window.location.href='/admin/jobs/<%= row.id %>/applications'">
          <div class="flex justify-between items-start">
            <div class="max-w-[70%]">
              <p class="text-xs font-black text-indigo-500 mb-1 uppercase">Job #0<%= index + 1 %></p>
              <h4 class="text-lg font-bold text-gray-900 leading-tight"><%= row.title %></h4>
              <p class="text-sm text-gray-500 mt-1"><%= row.company_name %></p>
            </div>
            <div class="text-right">
              <div class="text-2xl font-black text-gray-900"><%= row.count %></div>
              <div class="text-[10px] font-bold text-gray-400 uppercase">份申请</div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>