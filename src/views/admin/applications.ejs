<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8 lg:py-12">
  <!-- 页面标题 -->
  <div class="mb-8 sm:mb-12">
    <h1 class="text-3xl sm:text-4xl font-bold" style="color: var(--color-text-primary); margin-bottom: 0.5rem;">投递审核</h1>
    <p style="color: var(--color-text-tertiary); font-size: 0.95rem;">审核学生投递的岗位申请，共 <span class="font-semibold" style="color: var(--color-text-secondary);"><%= applications.length %></span> 条</p>
  </div>

  <% if (applications.length > 0) { %>
  <!-- 批量操作按钮 -->
  <div class="mb-6 sm:mb-8">
    <form method="post" action="/admin/applications/bulk-approve" class="inline-block">
      <button type="submit" class="px-6 py-3 font-semibold text-sm rounded-lg transition-all shadow-sm hover:shadow-md"
        style="background-color: var(--color-success-bg); color: var(--color-success); border: 1px solid var(--color-success-border); cursor: pointer;"
        onmouseover="this.style.backgroundColor='rgba(16, 185, 129, 0.15)'"
        onmouseout="this.style.backgroundColor='var(--color-success-bg)'"
        onclick="return confirm('确定要通过所有待审核的投递吗？')">
        ✓ 通过所有投递
      </button>
    </form>
  </div>
  <% } %>

  <% if (applications.length === 0) { %>
  <!-- 空状态 -->
  <div class="card p-12 text-center">
    <div style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.6;">📭</div>
    <h3 style="font-size: 1.125rem; margin-bottom: 0.5rem; color: var(--color-text-primary);">暂无投递</h3>
    <p style="color: var(--color-text-tertiary);">所有投递都已处理完毕</p>
  </div>
  <% } else { %>

  <!-- 桌面版：横向卡片列表 -->
  <div class="hidden md:block space-y-4">
    <% applications.forEach(function(app) { %>
    <div class="card p-6" style="padding: var(--spacing-card);">
      <div class="grid grid-cols-12 gap-6 items-center">
        
        <!-- 左侧：申请人信息 -->
        <div class="col-span-4">
          <p style="color: var(--color-text-tertiary); font-size: 0.875rem; margin-bottom: 0.375rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500;">申请人</p>
          <p style="font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.5rem; font-size: 1.05rem;"><%= app.name || '未填写' %></p>
          <p style="color: var(--color-text-secondary); font-size: 0.95rem;"><strong><%= app.title %></strong></p>
          <p style="color: var(--color-text-secondary); font-size: 0.75rem;"><%= app.company_name %></p>
        </div>

        <!-- 中间：时间和标签 -->
        <div class="col-span-3">
          <p style="color: var(--color-text-tertiary); font-size: 0.875rem; margin-bottom: 0.375rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500;">投递信息</p>
          <p class="mono" style="color: var(--color-text-primary); font-size: 0.9rem; margin-bottom: 0.5rem;">
            <%= new Date(app.created_at).toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' }) %>
          </p>
          <% if (app.status === 'pending') { %>
          <span class="badge badge-warning">待审核</span>
          <% } else if (app.status === 'approved') { %>
          <span class="badge badge-success">已通过</span>
          <% } else if (app.status === 'rejected') { %>
          <span class="badge badge-error">已拒绝</span>
          <% } %>
        </div>

        <!-- 右侧：操作 -->
        <div class="col-span-5 flex justify-end gap-3">
          <% if (app.status === 'pending') { %>
          <form method="post" action="/admin/applications/<%= app.id %>/review" class="inline">
            <input type="hidden" name="status" value="approved" />
            <button type="submit" class="px-4 py-2.5 font-semibold text-sm rounded-lg transition-all" 
              style="background-color: var(--color-success-bg); color: var(--color-success); border: 1px solid var(--color-success-border); cursor: pointer;"
              onmouseover="this.style.backgroundColor='rgba(16, 185, 129, 0.15)'"
              onmouseout="this.style.backgroundColor='var(--color-success-bg)'">
              ✓ 通过
            </button>
          </form>
          <form method="post" action="/admin/applications/<%= app.id %>/review" class="inline">
            <input type="hidden" name="status" value="rejected" />
            <button type="submit" class="px-4 py-2.5 font-semibold text-sm rounded-lg transition-all" 
              style="background-color: var(--color-error-bg); color: var(--color-error); border: 1px solid var(--color-error-border); cursor: pointer;"
              onmouseover="this.style.backgroundColor='rgba(239, 68, 68, 0.15)'"
              onmouseout="this.style.backgroundColor='var(--color-error-bg)'">
              ✕ 拒绝
            </button>
          </form>
          <% } else { %>
          <span style="color: var(--color-text-tertiary); font-size: 0.95rem; padding: 0.625rem 1rem;">已处理</span>
          <% } %>
        </div>

      </div>
    </div>
    <% }) %>
  </div>

  <!-- 移动版：卡片视图 -->
  <div class="md:hidden space-y-4">
    <% applications.forEach(function(app) { %>
    <div class="card p-5" style="padding: 1.25rem;">
      
      <!-- 标题部分 -->
      <div style="margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--color-border);">
        <p style="color: var(--color-text-tertiary); font-size: 0.8rem; margin-bottom: 0.375rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500;">申请人</p>
        <p style="font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.375rem; font-size: 1rem;"><%= app.name || '未填写' %></p>
        <p style="color: var(--color-text-secondary); font-size: 0.9rem;">岗位：<strong><%= app.title %></strong></p>
      </div>

      <!-- 时间和状态 -->
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--color-border);">
        <div>
          <p style="color: var(--color-text-tertiary); font-size: 0.8rem; margin-bottom: 0.25rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500;">投递时间</p>
          <p class="mono" style="color: var(--color-text-primary); font-size: 0.9rem;">
            <%= new Date(app.created_at).toLocaleDateString('zh-CN') %>
          </p>
        </div>
        <% if (app.status === 'pending') { %>
        <span class="badge badge-warning">待审核</span>
        <% } else if (app.status === 'approved') { %>
        <span class="badge badge-success">已通过</span>
        <% } else if (app.status === 'rejected') { %>
        <span class="badge badge-error">已拒绝</span>
        <% } %>
      </div>

      <!-- 操作按钮 -->
      <% if (app.status === 'pending') { %>
      <div style="display: flex; gap: 0.75rem;">
        <form method="post" action="/admin/applications/<%= app.id %>/review" class="flex-1">
          <input type="hidden" name="status" value="approved" />
          <button type="submit" class="w-full px-4 py-3 font-semibold text-sm rounded-lg transition-all" 
            style="background-color: var(--color-success-bg); color: var(--color-success); border: 1px solid var(--color-success-border); cursor: pointer;">
            ✓ 通过
          </button>
        </form>
        <form method="post" action="/admin/applications/<%= app.id %>/review" class="flex-1">
          <input type="hidden" name="status" value="rejected" />
          <button type="submit" class="w-full px-4 py-3 font-semibold text-sm rounded-lg transition-all" 
            style="background-color: var(--color-error-bg); color: var(--color-error); border: 1px solid var(--color-error-border); cursor: pointer;">
            ✕ 拒绝
          </button>
        </form>
      </div>
      <% } else { %>
      <p style="text-align: center; color: var(--color-text-tertiary); font-size: 0.95rem; padding: 0.75rem;">已处理，无法更改</p>
      <% } %>

    </div>
    <% }) %>
  </div>

  <% } %>
</div>

<style>
  /* 响应式网格调整 */
  @media (max-width: 1200px) {
    .grid-cols-12 { grid-template-columns: repeat(12, minmax(0, 1fr)); }
  }
  @media (max-width: 1024px) {
    /* 在平板尺寸调整列宽 */
  }
</style>