<div class="max-w-6xl mx-auto px-2 sm:px-4 lg:px-8 py-4 sm:py-6 lg:py-8">
  <!-- Header -->
  <div class="mb-6 sm:mb-8">
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">📋 岗位管理</h1>
    <p class="text-sm text-gray-500 mt-1 sm:mt-2">控制岗位在学生端的显示状态</p>
  </div>

  <% if (jobs.length === 0) { %>
  <!-- Empty State -->
  <div class="bg-white border border-gray-100 rounded-lg sm:rounded-xl shadow-sm p-8 sm:p-12 text-center">
    <p class="text-4xl sm:text-5xl mb-4">📭</p>
    <h3 class="text-lg sm:text-xl font-bold text-gray-900 mb-1">暂无岗位</h3>
    <p class="text-sm text-gray-500">系统中尚无岗位</p>
  </div>
  <% } else { %>
  
  <!-- Desktop Table View -->
  <div class="hidden md:block bg-white border border-gray-100 rounded-lg lg:rounded-xl shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-gray-50/50 border-b border-gray-100">
            <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-left">岗位名称</th>
            <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-left">所属企业</th>
            <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-center">显示状态</th>
            <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-center">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% jobs.forEach(function(job){ %>
          <tr class="hover:bg-gray-50/50 transition-colors duration-150">
            <td class="px-6 py-5 text-sm font-medium text-gray-900"><%= job.title %></td>
            <td class="px-6 py-5 text-sm text-gray-600"><%= job.company_name %></td>
            <td class="px-6 py-5 text-center">
              <% if (job.visible) { %>
              <span class="inline-flex items-center px-3 py-1 bg-emerald-50 text-emerald-700 text-xs font-semibold border border-emerald-200 rounded-full">
                👁️ 显示中
              </span>
              <% } else { %>
              <span class="inline-flex items-center px-3 py-1 bg-gray-100 text-gray-700 text-xs font-semibold border border-gray-200 rounded-full">
                🚫 已隐藏
              </span>
              <% } %>
            </td>
            <td class="px-6 py-5 text-center">
              <form method="post" action="/admin/jobs/<%= job.id %>/visibility" class="inline">
                <input type="hidden" name="visible" value="<%= job.visible ? 0 : 1 %>" />
                <button class="px-4 py-2 <%= job.visible ? 'bg-rose-600 hover:bg-rose-700' : 'bg-emerald-600 hover:bg-emerald-700' %> text-white text-xs font-semibold rounded-lg transition-colors">
                  <%= job.visible ? '🚫 隐藏' : '👁️ 显示' %>
                </button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Mobile Card View -->
  <div class="md:hidden space-y-3">
    <% jobs.forEach(function(job){ %>
    <div class="bg-white border border-gray-100 rounded-lg shadow-sm p-4">
      <h3 class="text-base font-semibold text-gray-900 mb-2 break-words"><%= job.title %></h3>
      <p class="text-sm text-gray-600 mb-3"><%= job.company_name %></p>
      
      <div class="flex items-center justify-between mb-3 pb-3 border-b border-gray-100">
        <p class="text-xs font-semibold text-gray-500 uppercase">显示状态</p>
        <% if (job.visible) { %>
        <span class="inline-flex items-center px-2.5 py-1 bg-emerald-50 text-emerald-700 text-xs font-semibold border border-emerald-200 rounded-full">
          👁️ 显示中
        </span>
        <% } else { %>
        <span class="inline-flex items-center px-2.5 py-1 bg-gray-100 text-gray-700 text-xs font-semibold border border-gray-200 rounded-full">
          🚫 已隐藏
        </span>
        <% } %>
      </div>

      <form method="post" action="/admin/jobs/<%= job.id %>/visibility" class="w-full">
        <input type="hidden" name="visible" value="<%= job.visible ? 0 : 1 %>" />
        <button class="w-full py-2 <%= job.visible ? 'bg-rose-600 hover:bg-rose-700' : 'bg-emerald-600 hover:bg-emerald-700' %> text-white text-sm font-semibold rounded-lg transition-colors">
          <%= job.visible ? '🚫 隐藏' : '👁️ 显示' %>
        </button>
      </form>
    </div>
    <% }) %>
  </div>

  <% } %>
</div>

