<div class="max-w-3xl mx-auto px-4 py-12">
  <div class="mb-10 text-center">
    <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">
      <%= job ? '编辑岗位' : '发布新岗位' %>
    </h1>
  </div>

  <% if (error) { %>
  <div class="mb-8 p-4 bg-rose-50 border border-rose-100 rounded-2xl animate-in fade-in slide-in-from-top-4">
    <div class="flex items-center text-rose-800">
      <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
      </svg>
      <span class="font-medium"><%= error %></span>
    </div>
  </div>
  <% } %>

  <form
    method="post"
    action="<%= job ? '/company/jobs/' + job.id : '/company/jobs' %>"
    class="bg-white border border-gray-100 shadow-[0_20px_50px_rgba(0,0,0,0.05)] rounded-3xl p-8 md:p-10"
  >
    <div class="space-y-8">
      <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 ml-1">
          岗位名称 <span class="text-rose-500">*</span>
        </label>
        <input
          type="text"
          name="title"
          class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 transition-all outline-none"
          value="<%= job ? job.title : '' %>"
          required
          placeholder="例如：英语交替口译"
        />
      </div>

      <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 ml-1">
          岗位描述 <span class="text-rose-500">*</span>
        </label>
        <textarea
          name="description"
          class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 transition-all outline-none resize-none"
          rows="5"
          required
          placeholder="详细描述岗位工作内容、职责等..."
        ><%= job ? job.description : '' %></textarea>
        <p class="mt-2 text-xs text-gray-400 flex items-center ml-1">
          <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20"><path d="M11 3a1 1 0 10-2 0v1a1 1 0 102 0V3zM5.884 6.607a1 1 0 011.414 0l.707.707a1 1 0 11-1.414 1.414l-.707-.707a1 1 0 010-1.414zm2.12 8.485a1 1 0 010 1.414l-.707.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-2.121-4.393a1 1 0 010 1.414l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 0zM12.586 3L12 3.586 11.414 3H12.586z"></path></svg>
          支持换行，建议详细描述工作内容
        </p>
      </div>

      <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 ml-1">
          岗位要求 <span class="text-rose-500">*</span>
        </label>
        <textarea
          name="requirement"
          class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 transition-all outline-none resize-none"
          rows="5"
          required
          placeholder="描述对候选人的要求，如学位、语言技能、工作经验等..."
        ><%= job ? job.requirement : '' %></textarea>
        <p class="mt-2 text-xs text-gray-400 ml-1">建议明确列出 3-5 条硬性要求</p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 pt-8 border-t border-gray-50">
        <button type="submit" class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3.5 px-6 rounded-2xl transition-all shadow-lg shadow-indigo-200 active:scale-[0.98] focus:ring-4 focus:ring-indigo-200">
          <%= job ? '保存所有修改' : '立即发布岗位' %>
        </button>
        <a href="/company/jobs" class="flex items-center justify-center px-6 py-3.5 text-gray-500 font-semibold hover:text-gray-700 hover:bg-gray-50 rounded-2xl transition-all">
          取消返回
        </a>
      </div>
    </div>
  </form>
</div>