<div class="max-w-6xl mx-auto px-2 sm:px-4 lg:px-0 py-4 sm:py-6 lg:py-10">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 sm:mb-10 gap-3 sm:gap-4">
    <div class="flex-1 min-w-0">
      <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight break-words">学生可见的岗位</h1>
      <p class="text-xs sm:text-base text-gray-500 mt-1 sm:mt-2 flex items-center">
        <span class="inline-block w-2 h-2 bg-green-500 rounded-full mr-2 flex-shrink-0"></span>
        管理发布的各个岗位需求
      </p>
    </div>
    <a href="/company/jobs/new" class="w-full sm:w-auto inline-flex items-center justify-center sm:justify-start px-4 sm:px-6 py-2.5 sm:py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-sm sm:text-base font-bold rounded-lg sm:rounded-2xl transition-all shadow-lg shadow-indigo-100 active:scale-95 flex-shrink-0">
      <svg class="w-4 sm:w-5 h-4 sm:h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
      <span class="hidden sm:inline">发布新岗位</span>
      <span class="sm:hidden">新岗位</span>
    </a>
  </div>

  <% if (jobs.length === 0) { %>
  <div class="bg-gray-50/50 border-2 border-dashed border-gray-200 rounded-lg sm:rounded-2xl py-12 sm:py-20 px-4 sm:px-6 text-center">
    <div class="w-16 sm:w-20 h-16 sm:h-20 bg-white rounded-2xl sm:rounded-3xl shadow-sm flex items-center justify-center mx-auto mb-4 sm:mb-6">
      <span class="text-3xl sm:text-4xl text-gray-300">💼</span>
    </div>
    <p class="text-sm sm:text-base text-gray-500 mb-6 sm:mb-8 max-w-sm mx-auto">目前还没有发布任何岗位</p>
    <a href="/company/jobs/new" class="inline-flex items-center px-6 sm:px-8 py-2.5 sm:py-3 bg-white border border-gray-200 text-gray-700 text-sm sm:text-base font-bold rounded-lg sm:rounded-xl hover:bg-gray-50 transition-all shadow-sm">
      立即创建第一个岗位
    </a>
  </div>
  <% } else { %>

  <!-- Desktop Table View -->
  <div class="hidden md:block bg-white border border-gray-100 shadow-[0_8px_30px_rgb(0,0,0,0.04)] rounded-lg lg:rounded-2xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead>
          <tr class="bg-gray-50/50 border-b border-gray-100">
            <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-widest">岗位名称</th>
            <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-widest">创建日期</th>
            <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-widest text-right">管理操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% jobs.forEach(function(job){ %>
          <tr class="group hover:bg-indigo-50/30 transition-all duration-200">
            <td class="px-6 py-6">
              <div class="flex items-center gap-3">
                <div class="hidden sm:flex w-10 h-10 bg-indigo-50 text-indigo-600 rounded-lg flex-shrink-0 items-center justify-center group-hover:bg-indigo-100 transition-colors">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </div>
                <div class="font-bold text-gray-900 text-sm sm:text-lg group-hover:text-indigo-700 transition-colors break-words">
                  <%= job.title %>
                </div>
              </div>
            </td>
            <td class="px-6 py-6">
              <div class="flex items-center text-gray-500 text-xs sm:text-sm">
                <svg class="w-4 h-4 mr-2 opacity-40 hidden sm:inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2v12a2 2 0 002 2z"></path></svg>
                <%= new Date(job.created_at).toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' }) %>
              </div>
            </td>
            <td class="px-6 py-6 text-right">
              <div class="flex justify-end gap-2">
                <a href="/company/jobs/<%= job.id %>/download-resumes" class="inline-flex items-center px-3 py-1.5 bg-white border border-gray-200 text-xs font-bold text-gray-600 rounded-lg hover:border-green-500 hover:text-green-600 transition-all shadow-sm">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                  下载
                </a>
                <a href="/company/jobs/<%= job.id %>/edit" class="inline-flex items-center px-3 py-1.5 bg-white border border-gray-200 text-xs font-bold text-gray-600 rounded-lg hover:border-indigo-500 hover:text-indigo-600 transition-all shadow-sm">
                  编辑
                </a>
                <form method="post" action="/company/jobs/<%= job.id %>/delete" style="display: inline;" onsubmit="return confirm('确定要删除这个岗位吗？删除后将清除所有相关投递记录。')">
                  <button type="submit" class="inline-flex items-center px-3 py-1.5 bg-white border border-gray-200 text-xs font-bold text-red-600 rounded-lg hover:border-red-500 hover:bg-red-50 transition-all shadow-sm">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    删除
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Mobile Card View -->
  <div class="md:hidden space-y-3">
    <% jobs.forEach(function(job){ %>
    <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-4">
      <div class="flex justify-between items-start gap-3 mb-3">
        <div class="flex-1 min-w-0">
          <h3 class="text-base font-bold text-gray-900 break-words">
            <%= job.title %>
          </h3>
          <p class="text-xs text-gray-500 mt-1">
            创建于 <%= new Date(job.created_at).toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' }) %>
          </p>
        </div>
      </div>
      
      <div class="flex gap-2">
        <a href="/company/jobs/<%= job.id %>/download-resumes" class="flex-1 inline-flex items-center justify-center px-2 py-2 bg-blue-50 border border-blue-200 text-xs font-bold text-blue-600 rounded-lg hover:bg-blue-100 transition-all">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          下载
        </a>
        <a href="/company/jobs/<%= job.id %>/edit" class="flex-1 inline-flex items-center justify-center px-2 py-2 bg-indigo-50 border border-indigo-200 text-xs font-bold text-indigo-600 rounded-lg hover:bg-indigo-100 transition-all">
          编辑
        </a>
        <form method="post" action="/company/jobs/<%= job.id %>/delete" style="display: contents;" onsubmit="return confirm('确定要删除?')">
          <button type="submit" class="flex-1 inline-flex items-center justify-center px-2 py-2 bg-red-50 border border-red-200 text-xs font-bold text-red-600 rounded-lg hover:bg-red-100 transition-all">
            删除
          </button>
        </form>
      </div>
    </div>
    <% }) %>
  </div>

  <% } %>
</div>