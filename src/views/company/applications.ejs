<div class="max-w-7xl mx-auto px-2 sm:px-4 lg:px-8 py-4 sm:py-6 lg:py-8">
  <div class="mb-6 sm:mb-10 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
    <div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">投递学生列表</h1>
      <p class="text-xs sm:text-sm text-gray-500 mt-1">共有 <span class="font-semibold text-blue-600"><%= applications.length %></span> 位学生应聘了您的岗位</p>
    </div>
  </div>

  <% if (applications.length === 0) { %>
  <div class="bg-gray-50/50 border-2 border-dashed border-gray-200 rounded-lg sm:rounded-2xl py-12 sm:py-20 px-4 sm:px-6 text-center">
    <div class="inline-flex items-center justify-center w-14 sm:w-16 h-14 sm:h-16 bg-white rounded-lg sm:rounded-2xl shadow-sm mb-3 sm:mb-4">
      <span class="text-2xl sm:text-3xl">📨</span>
    </div>
    <h3 class="text-lg sm:text-xl font-bold text-gray-900 mb-1">暂无投递记录</h3>
    <p class="text-xs sm:text-sm text-gray-500 max-w-xs mx-auto">还没有学生投递，或管理员尚未审核批准。只有通过审核的投递才会出现在这里。</p>
  </div>
  <% } else { %>

  <% jobGroups.forEach(function(group) { %>
  <!-- 按岗位分组 -->
  <div class="mb-6 sm:mb-8">
    <div class="bg-white border border-gray-100 shadow-sm rounded-lg sm:rounded-xl overflow-hidden">
      <!-- 岗位标题栏 -->
      <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border-b border-gray-100 px-3 sm:px-6 py-3 sm:py-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <h3 class="text-base sm:text-lg font-bold text-gray-900"><%= group.title %></h3>
          <p class="text-xs sm:text-sm text-gray-500 mt-1">投递数：<span class="font-semibold text-blue-600"><%= group.applications.length %></span> 位</p>
        </div>
        <a href="/company/jobs/<%= group.job_id %>/download-resumes" 
           class="w-full sm:w-auto inline-flex items-center justify-center px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-xs sm:text-sm font-bold rounded-lg sm:rounded-xl transition-all shadow-sm">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          <span class="hidden sm:inline">下载当前岗位简历</span>
          <span class="sm:hidden">下载</span>
        </a>
      </div>

      <!-- 学生列表 - Desktop -->
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="bg-gray-50/50 border-b border-gray-100">
              <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">学生信息</th>
              <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">简历材料</th>
              <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">投递时间</th>
              <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-right">操作</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% group.applications.forEach(function(app){ %>
            <tr class="hover:bg-blue-50/30 transition-colors duration-150 group">
              <td class="px-6 py-5">
                <div class="flex items-center">
                  <div class="h-8 w-8 rounded-full bg-gray-100 flex items-center justify-center text-gray-400 mr-3 text-xs font-bold ring-2 ring-white">
                    <%= (app.name || '未').substring(0,1) %>
                  </div>
                  <div class="text-sm font-medium text-gray-900"><%= app.name || '未填写姓名' %></div>
                </div>
              </td>
              <td class="px-6 py-5">
                <% if (app.resume_url) { %>
                <a href="<%= app.resume_url %>" target="_blank" class="inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors">
                  <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                  预览简历
                </a>
                <% } else { %>
                <span class="text-xs text-gray-400 bg-gray-100 px-2 py-1 rounded">未上传</span>
                <% } %>
              </td>
              <td class="px-6 py-5 text-sm text-gray-500 tabular-nums">
                <%= new Date(app.created_at).toLocaleDateString('zh-CN') %>
              </td>
              <td class="px-6 py-5 text-right">
                <a href="<%= app.resume_url %>" download target="_blank" 
                   class="inline-flex items-center px-4 py-2 border border-gray-200 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 hover:border-gray-300 transition-all">
                  <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                  下载
                </a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- 学生列表 - Mobile -->
      <div class="md:hidden space-y-2 divide-y divide-gray-100">
        <% group.applications.forEach(function(app){ %>
        <div class="p-3 sm:p-4">
          <div class="flex items-start gap-3 mb-3">
            <div class="h-8 w-8 rounded-full bg-gray-100 flex-shrink-0 flex items-center justify-center text-gray-400 text-xs font-bold ring-2 ring-white">
              <%= (app.name || '未').substring(0,1) %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-900"><%= app.name || '未填写姓名' %></p>
              <p class="text-xs text-gray-500 mt-0.5">
                <%= new Date(app.created_at).toLocaleDateString('zh-CN') %>
              </p>
            </div>
          </div>
          <div class="flex gap-2 flex-wrap">
            <% if (app.resume_url) { %>
            <a href="<%= app.resume_url %>" target="_blank" class="flex-1 inline-flex items-center justify-center px-2 py-2 bg-blue-50 border border-blue-200 text-xs font-bold text-blue-600 rounded-lg hover:bg-blue-100">
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
              预览
            </a>
            <a href="<%= app.resume_url %>" download target="_blank" class="flex-1 inline-flex items-center justify-center px-2 py-2 bg-green-50 border border-green-200 text-xs font-bold text-green-600 rounded-lg hover:bg-green-100">
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
              下载
            </a>
            <% } else { %>
            <span class="w-full text-center text-xs text-gray-400 bg-gray-100 px-2 py-2 rounded">未上传</span>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </div>
  <% }) %>

  <% } %>
</div>