<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-10 flex flex-col md:flex-row md:items-center md:justify-between">
    <div>
      <h1 class="text-2xl font-extrabold text-gray-900 tracking-tight">投递学生列表</h1>
      <p class="text-sm text-gray-500 mt-1">共有 <span class="font-semibold text-blue-600"><%= applications.length %></span> 位学生应聘了您的岗位</p>
    </div>
  </div>

  <% if (applications.length === 0) { %>
  <div class="bg-gray-50/50 border-2 border-dashed border-gray-200 rounded-3xl py-20 px-4 text-center">
    <div class="inline-flex items-center justify-center w-16 h-16 bg-white rounded-2xl shadow-sm mb-4">
      <span class="text-3xl">📨</span>
    </div>
    <h3 class="text-lg font-bold text-gray-900 mb-1">暂无投递记录</h3>
    <p class="text-gray-500 max-w-xs mx-auto text-sm">还没有学生投递，或管理员尚未审核批准。只有通过审核的投递才会出现在这里。</p>
  </div>
  <% } else { %>

  <% jobGroups.forEach(function(group) { %>
  <!-- 按岗位分组 -->
  <div class="mb-8">
    <div class="bg-white border border-gray-100 shadow-sm rounded-2xl overflow-hidden">
      <!-- 岗位标题栏 -->
      <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border-b border-gray-100 px-6 py-4 flex items-center justify-between">
        <div>
          <h3 class="text-lg font-bold text-gray-900"><%= group.title %></h3>
          <p class="text-sm text-gray-500 mt-1">投递数：<span class="font-semibold text-blue-600"><%= group.applications.length %></span> 位</p>
        </div>
        <a href="/company/jobs/<%= group.job_id %>/download-resumes" 
           class="inline-flex items-center px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-bold rounded-xl transition-all shadow-sm">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          下载当前岗位简历
        </a>
      </div>

      <!-- 学生列表表格 -->
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-gray-50/50 border-b border-gray-100">
              <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">学生信息</th>
              <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">简历材料</th>
              <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">投递时间</th>
              <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-right">操作</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% group.applications.forEach(function(app){ %>
            <tr class="hover:bg-blue-50/30 transition-colors duration-150 group">
              <td class="px-6 py-5">
                <div class="flex items-center">
                  <div class="h-8 w-8 rounded-full bg-gray-100 flex items-center justify-center text-gray-400 mr-3 text-xs font-bold ring-2 ring-white">
                    <%= (app.name || '未').substring(0,1) %>
                  </div>
                  <div class="text-sm font-medium text-gray-900"><%= app.name || '未填写姓名' %></div>
                </div>
              </td>
              <td class="px-6 py-5">
                <% if (app.resume_url) { %>
                <a href="<%= app.resume_url %>" target="_blank" class="inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors">
                  <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                  预览简历
                </a>
                <% } else { %>
                <span class="text-xs text-gray-400 bg-gray-100 px-2 py-1 rounded">未上传</span>
                <% } %>
              </td>
              <td class="px-6 py-5 text-sm text-gray-500 tabular-nums">
                <%= new Date(app.created_at).toLocaleDateString('zh-CN') %>
              </td>
              <td class="px-6 py-5 text-right">
                <a href="<%= app.resume_url %>" download target="_blank" 
                   class="inline-flex items-center px-4 py-2 border border-gray-200 shadow-sm text-sm font-medium rounded-xl text-gray-700 bg-white hover:bg-gray-50 hover:border-gray-300 transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                  <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                  下载
                </a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% }) %>

  <% } %>
</div>