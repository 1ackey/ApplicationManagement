<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8 lg:py-12">
  <!-- 页面标题 -->
  <div class="mb-8 sm:mb-12">
    <h1 class="text-3xl sm:text-4xl font-bold" style="color: var(--color-text-primary); margin-bottom: 0.5rem;">投递学生列表</h1>
    <p style="color: var(--color-text-tertiary); font-size: 0.95rem;">共有 <span class="font-semibold" style="color: var(--color-text-secondary);"><%= applications.length %></span> 位学生应聘了您的岗位</p>
  </div>

  <% if (applications.length === 0) { %>
  <!-- 空状态 -->
  <div class="card p-12 text-center">
    <div style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.6;">📨</div>
    <h3 style="font-size: 1.125rem; margin-bottom: 0.5rem; color: var(--color-text-primary);">暂无投递记录</h3>
    <p style="color: var(--color-text-tertiary);">还没有学生投递，或管理员尚未审核批准</p>
  </div>
  <% } else { %>

  <% jobGroups.forEach(function(group) { %>
  <!-- 岗位分组 -->
  <div style="margin-bottom: 2rem;">
    <div class="card overflow-hidden">
      
      <!-- 岗位标题栏 -->
      <div style="padding: var(--spacing-card); border-bottom: 1px solid var(--color-border);">
        <div style="display: grid; grid-template-columns: 1fr auto; gap: 1.5rem; align-items: start;">
          <div>
            <h3 style="font-size: 1.125rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.5rem;"><%= group.title %></h3>
            <p style="color: var(--color-text-tertiary); font-size: 0.9rem;">投递数：<span style="font-weight: 600; color: var(--color-text-secondary);"><%= group.applications.length %></span> 位</p>
          </div>
          <a href="/company/jobs/<%= group.job_id %>/download-resumes" 
             class="hidden sm:inline-flex items-center justify-center px-5 py-2.5 font-semibold text-sm rounded-lg transition-all" 
             style="background-color: var(--color-success-bg); color: var(--color-success); border: 1px solid var(--color-success-border); cursor: pointer;">
            ↓ 批量下载
          </a>
        </div>
      </div>

      <!-- 学生列表 - 桌面版 -->
      <div class="hidden md:block">
        <div style="border-top: 1px solid var(--color-border);">
          <% group.applications.forEach(function(app, idx) { %>
          <div class="<%= idx > 0 ? 'border-t' : '' %>" style="<%= idx > 0 ? 'border-color: var(--color-border);' : '' %>">
            <div style="padding: var(--spacing-card); display: grid; grid-template-columns: 2fr 1.5fr 1.2fr auto; gap: 2rem; align-items: center; transition: background-color var(--duration-base);" 
                 onmouseover="this.style.backgroundColor='rgba(59, 130, 246, 0.02)'" 
                 onmouseout="this.style.backgroundColor='transparent'">
              
              <!-- 学生信息 -->
              <div>
                <p style="color: var(--color-text-tertiary); font-size: 0.8rem; margin-bottom: 0.375rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500;">申请人</p>
                <p style="font-weight: 600; color: var(--color-text-primary);"><%= app.name || '未填写' %></p>
              </div>

              <!-- 简历状态 -->
              <div>
                <p style="color: var(--color-text-tertiary); font-size: 0.8rem; margin-bottom: 0.375rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500;">简历</p>
                <% if (app.resume_url) { %>
                <a href="<%= app.resume_url %>" target="_blank" class="badge badge-info" style="cursor: pointer;">
                  ✓ 已上传
                </a>
                <% } else { %>
                <span style="display: inline-flex; padding: 0.375rem 0.75rem; background-color: var(--color-border-light); color: var(--color-text-tertiary); border-radius: calc(var(--radius-default) / 2); font-size: 0.875rem;">
                  未上传
                </span>
                <% } %>
              </div>

              <!-- 投递时间 -->
              <div>
                <p style="color: var(--color-text-tertiary); font-size: 0.8rem; margin-bottom: 0.375rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500;">时间</p>
                <p class="mono" style="color: var(--color-text-primary); font-size: 0.9rem;"><%= new Date(app.created_at).toLocaleDateString('zh-CN') %></p>
              </div>

              <!-- 操作按钮 -->
              <% if (app.resume_url) { %>
              <a href="<%= app.resume_url %>" download target="_blank" 
                 class="px-4 py-2.5 font-semibold text-sm rounded-lg transition-all" 
                 style="background-color: var(--color-primary); color: white; border: 1px solid var(--color-primary); cursor: pointer; text-align: center;"
                 onmouseover="this.style.backgroundColor='var(--color-primary-hover)'"
                 onmouseout="this.style.backgroundColor='var(--color-primary)'">
                ↓ 下载
              </a>
              <% } else { %>
              <span style="color: var(--color-text-tertiary); font-size: 0.9rem;">暂无</span>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- 学生列表 - 移动版 -->
      <div class="md:hidden" style="padding: 0;">
        <% group.applications.forEach(function(app, idx) { %>
        <div class="<%= idx > 0 ? 'border-t' : '' %>" style="<%= idx > 0 ? 'border-color: var(--color-border); border-top: 1px solid;' : '' %>">
          <div style="padding: 1.25rem;">
            <!-- 学生信息 -->
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
              <div style="width: 2rem; height: 2rem; border-radius: 50%; background-color: var(--color-info-bg); display: flex; align-items: center; justify-content: center; font-weight: 600; color: var(--color-info);">
                <%= (app.name || '未').substring(0,1) %>
              </div>
              <div>
                <p style="font-weight: 600; color: var(--color-text-primary);"><%= app.name || '未填写' %></p>
                <p class="mono" style="color: var(--color-text-tertiary); font-size: 0.85rem;"><%= new Date(app.created_at).toLocaleDateString('zh-CN') %></p>
              </div>
            </div>

            <!-- 简历状态 -->
            <div style="margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--color-border);">
              <p style="color: var(--color-text-tertiary); font-size: 0.8rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500;">简历</p>
              <% if (app.resume_url) { %>
              <span class="badge badge-success">✓ 已上传</span>
              <% } else { %>
              <span style="display: inline-flex; padding: 0.375rem 0.75rem; background-color: var(--color-border-light); color: var(--color-text-tertiary); border-radius: calc(var(--radius-default) / 2); font-size: 0.875rem;">
                未上传
              </span>
              <% } %>
            </div>

            <!-- 操作按钮 -->
            <% if (app.resume_url) { %>
            <div style="display: flex; gap: 0.75rem;">
              <a href="<%= app.resume_url %>" target="_blank" 
                 class="flex-1 px-4 py-2.5 font-semibold text-sm rounded-lg transition-all" 
                 style="background-color: var(--color-info-bg); color: var(--color-info); border: 1px solid var(--color-info-border); text-align: center; cursor: pointer;">
                👁 预览
              </a>
              <a href="<%= app.resume_url %>" download target="_blank" 
                 class="flex-1 px-4 py-2.5 font-semibold text-sm rounded-lg transition-all" 
                 style="background-color: var(--color-success-bg); color: var(--color-success); border: 1px solid var(--color-success-border); text-align: center; cursor: pointer;">
                ↓ 下载
              </a>
            </div>
            <% } else { %>
            <p style="text-align: center; color: var(--color-text-tertiary); font-size: 0.9rem;">暂无简历可下载</p>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>

    </div>
  </div>
  <% }) %>

  <% } %>
</div>