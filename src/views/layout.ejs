<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <title>校企合作简历投递系统</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body class="bg-gradient-to-br from-gray-50 to-gray-100">
    <!-- Navigation -->
    <nav class="bg-gradient-to-r from-blue-600 to-blue-800 shadow-lg border-b-4 border-blue-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <!-- Logo -->
          <a href="/" class="text-2xl font-bold text-white hover:text-blue-100 transition">
            UIBE-英语学院简历投递系统
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex flex-1 justify-center space-x-4 ml-10">
            <% if (currentUser && currentUser.role === 'student') { %>
            <a href="/student/jobs" class="text-white hover:bg-blue-700 px-3 py-2 rounded-lg transition">岗位列表</a>
            <a href="/student/applications" class="text-white hover:bg-blue-700 px-3 py-2 rounded-lg transition">投递记录</a>
            <a href="/student/profile" class="text-white hover:bg-blue-700 px-3 py-2 rounded-lg transition">个人信息</a>
            <% } else if (currentUser && currentUser.role === 'company') { %>
            <a href="/company/jobs" class="text-white hover:bg-blue-700 px-3 py-2 rounded-lg transition">岗位管理</a>
            <a href="/company/applications" class="text-white hover:bg-blue-700 px-3 py-2 rounded-lg transition">投递学生</a>
            <% } else if (currentUser && currentUser.role === 'admin') { %>
            <a href="/admin/dashboard" class="text-white hover:bg-blue-700 px-3 py-2 rounded-lg transition">统计面板</a>
            <a href="/admin/applications" class="text-white hover:bg-blue-700 px-3 py-2 rounded-lg transition">投递审核</a>
            <a href="/admin/jobs" class="text-white hover:bg-blue-700 px-3 py-2 rounded-lg transition">岗位管理</a>
            <a href="/admin/students" class="text-white hover:bg-blue-700 px-3 py-2 rounded-lg transition">简历库</a>
            <% } %>
          </div>

          <!-- User Menu -->
          <div class="flex items-center space-x-4">
            <% if (currentUser) { %>
            <span class="text-white text-sm font-medium">
              <%= currentUser.username %> <span class="text-blue-100">(<%=  currentUser.role %>)</span>
            </span>
            <form method="post" action="/logout" class="inline">
              <button class="text-white hover:bg-blue-700 px-3 py-2 rounded-lg transition">退出</button>
            </form>
            <% } else { %>
            <a href="/login" class="text-white hover:bg-blue-700 px-3 py-2 rounded-lg transition">登录</a>
            <a href="/register" class="text-white hover:bg-blue-700 px-3 py-2 rounded-lg transition">注册</a>
            <% } %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 min-h-screen">
      <%- body %>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-300 mt-12 py-6 border-t-2 border-gray-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p>&copy; 2026 校企合作投递系统 | ALL RIGHTS RESERVED | 对系统的改进建议或bug请联系 mirmonsjackey@gmail.com</p>
      </div>
    </footer>
  </body>
</html>

